    "seo": {
      "title": " Shoulder CT Scan at Cadabams Diagnostics | Fast, Accurate Imaging ",
      "description": " Book a CT screening shoulder scan at Cadabams Diagnostics for detailed 3-D imaging that pinpoints rotator-cuff tears, fractures and arthritis in minutes.\n\n",
