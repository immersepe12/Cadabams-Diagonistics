    "faqs": [
      {
        "question": "Is MRI renal angiography painful?",
        "answer": "No. You’ll feel only a brief pinch when the IV goes in.\n"
      },
      {
        "question": "How long does the scan take?",
        "answer": "30–45 minutes on the table, plus 15 minutes of observation.\n"
      },
      {
        "question": "Can I eat after the scan?",
        "answer": "Yes. Resume your normal diet and hydration immediately.\n"
      },
      {
        "question": "When will I get results?",
        "answer": "Standard reports within 24 hours; same-day option available at Cadabams Diagnostics.\n"
      },
      {
        "question": "Is gadolinium dye safe?",
        "answer": "Yes, in patients with good kidney function. We screen every patient first.\n"
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "Our open-bore 3T MRI and mild sedation options keep you comfortable.\n"
      }
    ],
