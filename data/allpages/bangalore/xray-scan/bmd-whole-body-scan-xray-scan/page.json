    "faqs": [
      {
        "question": "Is the scan painful",
        "answer": "No—completely painless and non-invasive."
      },
      {
        "question": "How often should I repeat it?",
        "answer": "Every **1–2 years** if you have risk factors; **3–5 years** if stable."
      },
      {
        "question": "Can I eat before the scan?",
        "answer": "Yes, normal diet is allowed."
      },
      {
        "question": "Does insurance cover the test?",
        "answer": "Most policies cover osteoporosis screening; verify with your provider."
      },
      {
        "question": "What clothes should I wear?",
        "answer": "Loose, metal-free clothing. Cadabams supplies a gown if needed."
      }
