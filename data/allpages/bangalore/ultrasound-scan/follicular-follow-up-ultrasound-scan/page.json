    "faqs": [
      {
        "question": "How many scans per cycle?",
        "answer": "Usually **3–5 scans**, but PCOS or slow growers may need more."
      },
      {
        "question": "Is the scan painful?",
        "answer": "Most women feel **mild pressure**; the probe is smaller than a tampon."
      },
      {
        "question": "Can I eat before the scan?",
        "answer": "Yes. Fasting is **not required**."
      },
      {
        "question": "What if no dominant follicle is seen?",
        "answer": "We’ll advise further blood tests or adjust medication. **Next cycle planning** starts immediately."
      },
      {
        "question": "How soon can I try to conceive after the scan?",
        "answer": "**Same evening** if ovulation is imminent—no waiting period."
      }
