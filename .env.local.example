# Meilisearch configuration for Cadabam's Diagnostics search.
# Copy this file to `.env.local` and fill in the real values from your instance.
#
#   cp .env.local.example .env.local
#
# Confirm the host + keys against your dashboard, and verify the index UIDs with:
#   curl -H "Authorization: Bearer <ADMIN_KEY>" '<HOST>/indexes'

# ---------------------------------------------------------------------------
# PUBLIC — these are inlined into the browser bundle (NEXT_PUBLIC_ prefix).
# The search-only key is read-only and SAFE to expose to the browser.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MEILI_HOST=https://cms-search.cadabams.com
NEXT_PUBLIC_MEILI_SEARCH_KEY=46b0e73be0e8b4a39da6a4aa489fbfb627478082854f80d9a1a9b2aad915a457

# ---------------------------------------------------------------------------
# SERVER-ONLY — used exclusively by scripts/index-meili.ts to push documents.
# The admin key can create/delete data. NEVER prefix it with NEXT_PUBLIC_ and
# NEVER reference it from any client component.
# ---------------------------------------------------------------------------
MEILI_ADMIN_KEY=your_admin_key
