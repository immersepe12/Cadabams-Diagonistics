    "faqs": [
      {
        "question": "Is the procedure painful?",
        "answer": "Most feel only a small sting; local anesthetic numbs the area within seconds."
      },
      {
        "question": "How long does pain relief last?",
        "answer": "Corticosteroids: 4–12 weeks; hyaluronic acid: up to 6 months; PRP results build over 6–12 weeks."
      },
      {
        "question": "Can I drive home?",
        "answer": "Yes, unless you have received a sedative (rare)."
      },
      {
        "question": "How soon can I resume sports",
        "answer": "Light activity same day; full return in 48–72 hours unless advised otherwise."
      },
      {
        "question": "What if I’m on blood thinners?",
        "answer": "Inform us—your dose may be adjusted or injection timed safely."
      }
