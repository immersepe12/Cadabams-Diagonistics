    "faqs": [
      {
        "question": "Is MRI foot painful?",
        "answer": "No. The scan is painless; you only need to stay still.\n"
      },
      {
        "question": "Can I walk after the scan?",
        "answer": "Yes. There are no restrictions unless you received sedation.\n"
      },
      {
        "question": "How much does an MRI foot cost?",
        "answer": "Standard scan ₹6,500; with contrast ₹8,500. Insurance & cashless options available."
      },
      {
        "question": "Do I need contrast?",
        "answer": "Only if infection, tumour, or post-surgical scarring is suspected.\n"
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "We offer open-bore 3T, music, and mild sedation. Inform us when booking.\n"
      }
