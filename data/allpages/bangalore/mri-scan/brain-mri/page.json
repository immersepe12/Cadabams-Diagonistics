    "faqs": [
      {
        "question": "How long does an MRI Brain take?",
        "answer": "15–25 minutes without contrast; add 5 min if contrast is used.\n"
      },
      {
        "question": "Is MRI Brain painful?",
        "answer": "No. You only feel the IV pinch if contrast is given.\n"
      },
      {
        "question": "Can I eat before an MRI Brain?",
        "answer": "Yes, regular meals are allowed.\n"
      },
      {
        "question": "What if I am claustrophobic?",
        "answer": "We offer wide-bore 70 cm scanner, mirror glasses, music, or oral sedation.\n"
      },
      {
        "question": "When will I get my MRI Brain results?",
        "answer": "Same day by 6 p.m. for routine scans; instantly for emergencies.\n"
      },
      {
        "question": " Main Difference Between MRI with and Without Contrast",
        "answer": " An **MRI Brain Scan** *without* contrast provides anatomical detail. An **MRI with contrast** shows tumors, inflammation, or vascular issues, as contrast enhances visibility."
      }
    ],
