    "faqs": [
      {
        "question": "Is MRI Defecography painful?",
        "answer": "No. The contrast tube is smaller than a typical enema nozzle; most feel only mild pressure.\n"
      },
      {
        "question": "How long does the procedure take?",
        "answer": "Actual scanning is 20–30 minutes; plan one hour including preparation.\n"
      },
      {
        "question": "Can I eat before the test?",
        "answer": " A light, low-fiber meal 4 hours earlier is fine. Avoid heavy meals.\n"
      },
      {
        "question": "When will I get my results?",
        "answer": "We email or courier reports within **one business day**.\n"
      },
      {
        "question": "Is the contrast agent safe?",
        "answer": "Yes—made from **inert gel** that mimics stool; no allergies reported.\n"
      },
      {
        "question": "Do I need a referral?",
        "answer": "A **doctor’s prescription** ensures the scan targets the right clinical question; walk-ins accepted with prior GP note.\n"
      }
    ],
