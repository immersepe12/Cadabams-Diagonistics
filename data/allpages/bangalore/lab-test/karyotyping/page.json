      "reportsWithin": "",
      "Identifies": "Numerical and structural abnormalities in chromosomes.",
      "measures": "The number, size, and shape of chromosomes within a cell sample.",
      "price": 6000,
      "testCategory": "Biochemistry"
    },
    "requisites": [
      {
        "value": "Typically a blood sample; however, the Karyotyping test can also be performed on samples of amniotic fluid, chorionic villus sample (CVS), bone marrow, or other tissues, depending on the clinical indication."
      }
    ],
    "packages": [],
