    "faqs": [
      {
        "question": "How long does the epilepsy protocol MRI take?",
        "answer": "About 30–40 minutes total.\n"
      },
      {
        "question": "Is the scan painful?",
        "answer": "No, it is completely painless. You just need to lie still.\n"
      },
      {
        "question": "Can I eat before the test?",
        "answer": "Yes, a light meal is allowed unless you’re scheduled for sedation.\n"
      },
      {
        "question": "When will I get my report?",
        "answer": "Same day by 6 p.m. if your scan finishes before noon.\n"
      },
