    "faqs": [
      {
        "question": "Is the Abdomen Doppler ultrasound painful?",
        "answer": "No. The scan is painless; you may feel mild pressure."
      },
      {
        "question": "How long does the scan take?",
        "answer": "15–25 minutes in most cases."
      },
      {
        "question": "Can I eat after the test?",
        "answer": "Yes, you can eat and drink immediately."
      },
      {
        "question": "When will I get my report?",
        "answer": "Within 3 hours; urgent cases within 1 hour."
      },
      {
        "question": "Do I need a follow-up scan?",
        "answer": "This depends on your doctor’s treatment plan. If monitoring liver disease or transplant, periodic scans every 6–12 months are common."
      }
