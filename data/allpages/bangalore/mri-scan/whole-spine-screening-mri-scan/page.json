    "interpretations": {
      "title": "MRI Whole Spine Screening Results and Interpretations:",
      "cols": [
        "Finding / Observation",
        "What Radiologists Look For",
        "General Interpretation/Significance if Abnormal"
      ],
      "rows": [
        [
          "Vertebral Alignment",
          "Straightness, curves (scoliosis, kyphosis)",
          "Abnormal curves can cause pain, nerve issues, and postural problems."
        ],
        [
          "Vertebral Bodies",
          "Bone height, signal (breaks, tumors, inflammation)",
          "Can indicate fractures, bone lesions, signs of infection, or inflammatory changes."
        ],
        [
          "Disc dehydration",
          "Dark T2 signal at L4-L5",
          "Early degenerative change"
        ],
        [
          "Spinal Canal",
          "The amount of space available for the spinal cord",
          "Narrowing (stenosis) can compress the spinal cord or nerves, causing significant symptoms."
        ],
        [
          "Spinal Cord",
          "Its size, shape, and signal (lesions, swelling)",
          "May reveal cysts (syrinx), tumors, inflammation (e.g., MS plaques), or cord compression."
        ],
        [
          "Cord hyperintensity",
          "Bright STIR at C5-C6",
          "Possible myelomalacia or MS plaque"
        ],
        [
          "Facet Joints",
          "Signs of arthritis (inflammation, bone spurs)",
          "Arthritis in these joints can be a major contributor to chronic back pain and stiffness."
        ],
        [
          "Marrow lesion",
          "Hypointense T1 at D8",
          "Rule out metastasis"
        ]
      ]
    },
    "faqs": [
      {
        "question": "How long does the scan take?",
        "answer": "About 25 minutes without contrast; 30 minutes with contrast.\n"
      },
      {
        "question": "Is there any pain or injection?",
        "answer": "No pain. An IV line is placed only if contrast is required.\n"
      },
      {
        "question": "Can I drive home after?",
        "answer": "Yes, unless you take sedation—then arrange a companion.\n"
      },
      {
        "question": "What if I’m pregnant?",
        "answer": "Inform our team; we follow international guidelines and decide case-by-case.\n"
      },
      {
        "question": "Do I need a doctor’s prescription?",
        "answer": "Yes, a simple referral letter or digital prescription is sufficient.\n"
      },
      {
        "question": "What should I do if the screening shows an abnormality?",
        "answer": "Your referring doctor will carefully review the report with you. They will explain what any findings mean, answer all your questions, and recommend the best next steps, which could involve further evaluation, lifestyle changes, physical therapy, or other treatments."
      }
    ],
