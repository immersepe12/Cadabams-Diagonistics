        [
          "Aortic aneurysm",
          "Dilated aorta measuring 3–4.9 cm, no rupture signs",
          "Requires surveillance and medical management "
        ],
        [
          "Large aneurysm or rapid growth",
          "Aorta diameter ≥ 5 cm or growth > 0.5 cm/year  ",
          "Surgical intervention recommended to prevent rupture  "
        ],
        [
          "Aortic dissection (Stanford A)",
          " Tear involving ascending aorta             ",
          " Emergency surgical treatment necessary "
        ],
        [
          "Aortic dissection (Stanford B)",
          "Tear confined to descending aorta   ",
          " Usually managed medically unless complications arise"
        ]
      ]
