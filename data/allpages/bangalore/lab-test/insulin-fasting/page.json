    "seo": {
      "title": "Fasting Insulin Test – Purpose, Levels & Price",
      "description": "Understand the fasting insulin test, its importance in detecting insulin resistance, normal levels, pricing, and how to prepare for accurate results.",
      "keywords": "",
      "canonicalUrl": "",
      "ogTitle": "",
      "ogDescription": "",
