    "seo": {
      "title": "Guided Biopsy Ultrasound: Fast, Safe, Precise Scan",
      "description": "Guided Biopsy Ultrasound Scan at Cadabams: Accurate, same-day tissue sampling for suspicious lumps. No radiation, minimal downtime. Get clear answers.",
      "keywords": "",
      "canonicalUrl": "",
      "ogTitle": "",
      "ogDescription": "",
