    "seo": {
      "title": "MRI Neck Without Contrast at Cadabams Diagnostics | Fast & Safe ",
      "description": "Book your MRI Neck Without Contrast at Cadabams Diagnostics—zero radiation, 15-minute scan, digital report in 2 hours. Same-day slots available.\n",
      "keywords": "",
      "canonicalUrl": "",
      "ogTitle": "",
      "ogDescription": "",
