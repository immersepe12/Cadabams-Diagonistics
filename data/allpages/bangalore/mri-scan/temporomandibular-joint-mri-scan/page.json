    "faqs": [
      {
        "question": "How long does the MRI take?",
        "answer": "About 20–30 minutes for both joints.\n"
      },
      {
        "question": "Is contrast dye necessary?",
        "answer": "Usually no; contrast is given only if tumour or severe inflammation suspected.\n"
      },
      {
        "question": "Can I eat before the scan?",
        "answer": "Yes, meals are permitted.\n"
      },
      {
        "question": "When will I get results?",
        "answer": "Preliminary report immediately; final report within 2 hours.\n"
      },
      {
        "question": "Does insurance cover TMJ MRI?",
        "answer": "Most policies cover medically indicated scans; our front-desk helps with pre-authorisation.\n"
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "We offer a wide-bore scanner, mirror goggles, music, and mild sedation.\n"
      }
