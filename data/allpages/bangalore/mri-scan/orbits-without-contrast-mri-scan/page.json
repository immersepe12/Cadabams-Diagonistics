    "faqs": [
      {
        "question": "Does it hurt?",
        "answer": "No. The scan is painless and non-invasive.\n"
      },
      {
        "question": "Can I drive after the scan?",
        "answer": "Yes, unless you took sedation—then arrange a driver.\n"
      },
      {
        "question": "How much does it cost?",
        "answer": "Prices start at ₹8,000 ; check the Cadabams website for current offers.\n"
      },
      {
        "question": "Is sedation available for kids?",
        "answer": "Yes, mild oral sedation can be arranged for anxious children.\n"
      },
      {
        "question": "Will insurance cover it?",
        "answer": "Most policies cover orbital MRI; our front desk can pre-authorize on your behalf.\n"
      }
