    "seo": {
      "title": "Pregnancy Interval Growth Scan with BPP & Doppler at Cadabams",
      "description": "Pregnancy Growth Scan (with BPP & Doppler): Vital for monitoring fetal growth, procedure details, and benefits explained. Expert care at Cadabams.",
      "keywords": "",
      "canonicalUrl": "",
      "ogTitle": "",
