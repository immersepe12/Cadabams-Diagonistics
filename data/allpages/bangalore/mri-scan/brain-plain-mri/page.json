    "faqs": [
      {
        "question": "How long does an MRI Brain Plain take?",
        "answer": "15–25 minutes inside the scanner, plus 15 minutes preparation.\n"
      },
      {
        "question": "Is fasting required?",
        "answer": "No, unless you’re also having an MR spectroscopy add-on.\n"
      },
      {
        "question": "When will I receive my results?",
        "answer": "Reports are released within 2–4 working hours.\n"
      },
      {
        "question": "Can I drive home after the scan?",
        "answer": "Yes, no sedation is used."
      },
      {
        "question": "Is MRI Brain Plain safe for children?",
        "answer": "Absolutely; child-friendly staff and optional anesthesia support are available.\n"
      },
      {
        "question": "What if I feel claustrophobic?",
        "answer": "Ask for an open MRI or mild oral sedative prescribed beforehand.\n"
      }
    ],
