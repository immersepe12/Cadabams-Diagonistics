    "faqs": [
      {
        "question": "Does a shoulder CT scan hurt?",
        "answer": " No. It’s completely painless; you only need to stay still.\n"
      },
      {
        "question": "How long is the radiation exposure?",
        "answer": " Equivalent to about 6–8 months of natural background radiation—safe for most adults.\n\n"
      },
      {
        "question": "Can I drive home after the scan?",
        "answer": " Yes, unless you were sedated (rare). Contrast dye does not affect alertness.\n"
      },
      {
        "question": "Is fasting necessary?",
        "answer": " Fasting 2–3 hours is advised only if contrast is used; otherwise no.\n\n"
      },
      {
        "question": "How often can I have a CT scan?",
        "answer": " Only when clinically justified; cumulative radiation is tracked in your Cadabams health record.\n"
      }
