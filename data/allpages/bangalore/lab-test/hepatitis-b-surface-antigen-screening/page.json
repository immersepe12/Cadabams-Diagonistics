      {
        "question": "What does a positive HBsAg card test mean?",
        "answer": "A reactive result suggests an active infection (acute or chronic). Requires confirmation."
      },
      {
        "question": "How accurate is the rapid HBsAg card test?",
        "answer": "High-quality kits are generally accurate but slightly less sensitive than lab-based tests."
      },
      {
        "question": "How quickly are results available?",
        "answer": "Within 15–30 minutes."
      },
      {
        "question": "Do I need to fast?",
        "answer": "No, fasting is not necessary."
      },
      {
        "question": "How is it different from other Hepatitis B tests",
        "answer": "This test detects HBsAg only. Others assess antibodies, viral load, or immune status."
      },
      {
        "question": "What if my test is positive?",
        "answer": "See your doctor for confirmatory testing and guidance on next steps."
      }
