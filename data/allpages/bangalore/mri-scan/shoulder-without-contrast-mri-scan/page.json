    "interpretations": {
      "title": "Results and Interpretations ",
      "cols": [
        "Finding / Observation",
        "Description (What Radiologists Look For)",
        "General Interpretation / Significance"
      ],
      "rows": [
        [
          "High T2 signal in supraspinatus tendon",
          "Bright line within tendon",
          "Possible partial tear"
        ],
        [
          "Irregular labral contour",
          "Labrum appears frayed",
          "Labral tear or degeneration"
        ],
        [
          "Subacromial bursal fluid",
          "Bright stripe above rotator cuff",
          "Bursitis or impingement"
        ],
        [
          "Humeral head cartilage thinning",
          "Dark band < 2 mm",
          "Early osteoarthritis"
        ],
        [
          "Joint capsule thickening",
          "Capsule > 4 mm",
          "Adhesive capsulitis"
        ],
        [
          "Biceps Tendon (Long Head)",
          "Assess position in bicipital groove, signal intensity, partial tears, tendinosis, or tenosynovitis (fluid around tendon sheath).",
          "Pathology here is common with rotator cuff disease and contributes to anterior shoulder pain."
        ],
        [
          "Acromioclavicular (AC) Joint",
          "Examine for joint space narrowing, osteophytes, subchondral cysts, bone edema, and distal clavicle osteolysis.",
          "Suggests degenerative arthropathy or impingement syndrome, and may correlate with pain during overhead activity."
        ],
        [
          "Soft Tissues (Muscles, Fat Planes)",
          "Evaluate for muscle edema, atrophy, tears, or fatty infiltration. Assess surrounding fat planes for fluid collections or masses.",
          "Reflects muscle injury or chronic denervation. Fatty atrophy often correlates with longstanding tendon tears."
        ]
      ]
    },
    "faqs": [
      {
        "question": "How long does the scan take?",
        "answer": "15–20 minutes for routine sequences."
      },
      {
        "question": "Is the procedure painful?",
        "answer": "No. You may feel mild warmth; no injections or contrast.\n"
      },
      {
        "question": "When will I receive my report?",
        "answer": "Within 24 hours; urgent reports in 2 hours at Cadabams Diagnostics.\n"
      },
      {
        "question": "Can I eat or drink before the scan?",
        "answer": "Yes—no fasting required for MRI shoulder without contrast.\n"
      },
      {
        "question": "Will insurance cover this test?",
        "answer": "Most policies cover it; Cadabams offers cashless approval in 30 minutes.\n"
      },
      {
