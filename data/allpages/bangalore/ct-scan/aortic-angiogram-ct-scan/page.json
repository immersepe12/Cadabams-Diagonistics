    "faqs": [
      {
        "question": "Does a CT AORTIC ANGIOGRAM hurt?",
        "answer": " No. You feel a brief warm flush when contrast goes in.\n"
      },
      {
        "question": "  How long does the whole visit take?",
        "answer": " 30 minutes—15 min preparation, 5 min scan, 10 min observation.\n"
      },
      {
        "question": " Can I drive home afterwards?",
        "answer": " Yes, unless you took sedation for claustrophobia (rare).\n"
      },
      {
        "question": "Is the radiation dose safe?",
        "answer": " We use dose-reduction software; risk is negligible compared with missing a dissection.\n"
      },
      {
        "question": "What if my creatinine is borderline?",
        "answer": " Our nephrologist reviews the case; hydration protocol or alternative MRI may be offered.\n"
      }
    ],
