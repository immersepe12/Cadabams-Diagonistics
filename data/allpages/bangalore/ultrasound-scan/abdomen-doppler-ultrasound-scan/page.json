    "seo": {
      "title": "Abdomen Doppler Ultrasound Scan | Cadabams Diagnostics",
      "description": "An Abdomen Doppler scan at Cadabams Diagnostics checks blood flow in the liver, kidneys and major vessels without radiation. Book your painless scan today.",
      "keywords": "",
      "canonicalUrl": "",
