    "seo": {
      "title": "MSK Guided Injection 1 Ultrasound Scan – Fast, Precise Pain Relief",
      "description": "Learn how Cadabams Diagnostics uses real-time ultrasound to deliver targeted MSK guided injections in under 30 minutes, relieving joint and tendon pain safely.",
