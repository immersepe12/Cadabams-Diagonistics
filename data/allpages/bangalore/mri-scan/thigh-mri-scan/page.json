      "rows": [
        [
          "Normal muscle",
          "Uniform dark signal on T1, intermediate on T2",
          "No tear or strain"
        ],
        [
          "Hamstring tear",
          "Bright T2 signal within muscle belly",
          "Grade 1–3 strain"
        ],
        [
          "Stress fracture",
          "Dark line in bone marrow with surrounding edema",
          "Needs rest ± surgery"
        ],
        [
          "Bone Marrow Edema in Femur",
          "Increased signal within the femoral marrow on fluid-sensitive sequences.",
          "Can indicate bone contusion, early stress reaction, infection (osteomyelitis), or reactive changes due to adjacent pathology."
        ],
        [
          "Soft-tissue mass",
          "Irregular enhancing lesion",
          "May require biopsy"
        ],
        [
          "Fluid Collection",
          "Accumulation of fluid (simple, complex, hemorrhagic, or purulent); may be encapsulated or not.",
          "Suggests hematoma, abscess, seroma, or postoperative fluid. Management may include drainage or aspiration based on clinical context."
        ],
        [
          "Nerve Appearance",
          "Evaluation of nerve signal and course (e.g., sciatic nerve). May appear thickened or hyperintense.",
          "Suggests neuritis, compression (e.g., piriformis syndrome), trauma, or displacement due to adjacent mass."
        ]
      ]
