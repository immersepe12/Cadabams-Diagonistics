    "seo": {
      "title": "MRI Brain Navigation Protocol at Cadabams Diagnostics | Safe & Precise",
      "description": "Learn how the MRI Brain Navigation Protocol at Cadabams Diagnostics helps doctors plan safer brain surgeries with 3D mapping, no radiation, and faster recovery.\n",
      "keywords": "",
      "canonicalUrl": "",
