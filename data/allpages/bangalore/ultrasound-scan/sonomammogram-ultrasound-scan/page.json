    "faqs": [
      {
        "question": "Is the sonomammogram painful?",
        "answer": "No, it is painless; only light pressure is applied."
      },
      {
        "question": "How soon will I get results?",
        "answer": "Preliminary results within 2 hours; full report emailed the same day."
      },
      {
        "question": "Do I need to fast?",
        "answer": "No fasting is required. Eat normally."
      },
      {
        "question": "Can I go alone?",
        "answer": "Yes, unless you feel anxious. One companion is welcome."
      },
      {
        "question": "What if a lump is found?",
        "answer": "The radiologist may recommend a **targeted biopsy** for confirmation."
      },
      {
        "question": "Is it safe during pregnancy?",
        "answer": "Absolutely—there is no radiation."
      }
