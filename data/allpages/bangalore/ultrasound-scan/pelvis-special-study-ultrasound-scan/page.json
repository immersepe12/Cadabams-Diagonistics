    "faqs": [
      {
        "question": "Is the scan painful?",
        "answer": "Discomfort is minimal; transvaginal probes are slender and well-lubricated."
      },
      {
        "question": "Can I eat before the scan?",
        "answer": "Yes, unless fasting is requested for an additional abdominal study."
      },
      {
        "question": "How soon will I get my results?",
        "answer": "Same day for routine scans; urgent cases within 1 hour."
      },
      {
        "question": "Do I need a full bladder?",
        "answer": "Only for transabdominal scans. You’ll be told when to empty it."
      },
      {
        "question": "Is it safe during pregnancy?",
        "answer": "Absolutely—ultrasound has no radiation."
      },
      {
        "question": "What if an abnormality is found?",
        "answer": "Our radiologist will discuss findings with your doctor and recommend next steps."
      }
