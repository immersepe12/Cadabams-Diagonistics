    "requisites": [],
    "interpretations": {
      "title": "Results and Interpretations ",
      "cols": [
        "Finding / Observation",
        "Description (Example)",
        "Interpretation "
      ],
      "rows": [
        [
          "Intact ACL & PCL",
          "Continuous, low-signal bands",
          "No tear"
        ],
        [
          "Horizontal meniscal tear",
          "High signal reaching articular surface",
          "Likely needs arthroscopy"
        ],
        [
          "Cartilage thinning <50 %",
          "Focal signal change",
          "Early osteoarthritis"
        ],
        [
          "Bone marrow edema",
          "Patchy high signal",
          "Recent injury or stress"
        ],
        [
          "Bone Marrow (e.g., Bone Edema)",
          "Areas of increased signal intensity on fluid-sensitive sequences (e.g., STIR or T2 FS) within subchondral bone.",
          "Suggestive of bone contusion, stress reaction, osteochondral injury, or early inflammatory changes."
        ],
        [
          "Joint Effusion",
          "Excess intra-articular fluid causing distension of the knee joint capsule.",
          "A non-specific finding. May indicate inflammation, trauma, or internal derangement (e.g., ligament/meniscus tear)."
        ],
        [
          "Tendons (e.g., Normal Patellar Tendon)",
          "Homogeneous low signal with intact tendon fibers and normal thickness",
          "No evidence of tendinopathy, tear, or inflammation. Indicates healthy tendon structure."
        ],
        [
          "Tendons (e.g., Patellar Tendinopathy)",
          "Thickened tendon with increased signal intensity on T1 or STIR images; may have partial-thickness tear.",
          "Represents degeneration or inflammation of the tendon (jumper's knee). Common cause of anterior knee pain."
        ],
        [
          "Baker’s Cyst",
          "Well-circumscribed fluid-filled collection in the popliteal fossa, often with neck extending to joint capsule.",
          "Usually secondary to intra-articular pathology (e.g., meniscal tear or arthritis). May cause posterior knee fullness."
        ]
      ]
    },
    "faqs": [
      {
        "question": "How long does the scan take?",
        "answer": "20–30 minutes for most cases.\n"
      },
      {
        "question": "Is the scan painful?",
        "answer": "No, but lying still may feel mildly uncomfortable.\n"
      },
      {
        "question": "Can I eat before the MRI?",
        "answer": "Yes—no fasting required for knee MRI without contrast.\n"
      },
      {
        "question": "When will I get results?",
        "answer": "Reports are available within 24 hours; urgent cases the same day.\n"
      },
      {
        "question": "Is sedation needed?",
        "answer": "Rarely—only if severe claustrophobia or pediatric patients."
      },
      {
        "question": "What are the next steps after my MRI Knee Without Contrast?",
        "answer": "After your **MRI Knee Without Contrast** at Cadabams Diagnostics, the radiologist will interpret the images and send a report to your referring physician. Your physician will then review these results in conjunction with your symptoms and clinical findings. The next step is usually a follow-up appointment with your doctor to discuss the diagnosis and collaboratively decide on the most appropriate treatment plan. This may involve physical therapy, medication, lifestyle modifications, or, in some cases, surgical intervention. "
      }
    ],
