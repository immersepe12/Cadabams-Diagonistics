    "seo": {
      "title": "Right Lower Limb Arterial Doppler Ultrasound",
      "description": "Doppler Arterial Lower Limb - Right Ultrasound: Detects leg circulation issues early. No needles, no radiation, and same-day results at Cadabams.",
      "keywords": "",
      "canonicalUrl": "",
      "ogTitle": "",
