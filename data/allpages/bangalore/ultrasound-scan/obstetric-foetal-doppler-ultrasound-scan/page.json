    "faqs": [
      {
        "question": "Is the Doppler scan safe for my baby? ",
        "answer": "Yes. Multiple international guidelines confirm no known risks from sound-wave technology."
      },
      {
        "question": "How long does the scan take?",
        "answer": "Most sessions last **15–30 minutes**, but allow extra time if baby is sleeping or in an awkward position."
      },
      {
        "question": "Do I need to fast before the scan?",
        "answer": "No fasting is required; a light snack can even encourage foetal movement for clearer images."
      },
      {
        "question": "When will I get the report?",
        "answer": "Preliminary findings are discussed on the spot; the final report is emailed or ready for pickup within 24 hours."
      },
      {
        "question": "Can I bring a family member?",
        "answer": "Absolutely. One adult is welcome in the scan room to share the moment and support you."
      }
