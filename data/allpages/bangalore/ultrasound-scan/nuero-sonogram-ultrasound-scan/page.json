    "faqs": [
      {
        "question": "Is the test painful for my baby?",
        "answer": "No. The probe just touches the soft spot; babies usually sleep through it."
      },
      {
        "question": "How soon can I get results?",
        "answer": "Preliminary results before you leave; full report within 3 hours during working days at Cadabams Diagnostics."
      },
      {
        "question": "Can it detect autism?",
        "answer": "No. Autism spectrum disorder is diagnosed later through developmental assessments."
      },
      {
        "question": "Is repeat scanning safe?",
        "answer": "Yes. Because there is no radiation, repeat scans are safe when medically needed."
      },
      {
        "question": "What if the fontanelle is small?",
        "answer": "Our paediatric radiologists use extra-soft probes and alternate angles (posterior fontanelle) to obtain quality images."
      }
    ],
