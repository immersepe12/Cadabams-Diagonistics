    "faqs": [
      {
        "question": "Is MRI MRCP painful?",
        "answer": "No. You only feel the table move.\n"
      },
      {
        "question": "How long does the scan take?",
        "answer": "15–20 minutes inside the machine; 30 minutes total visit.\n"
      },
      {
        "question": "Can I eat after the scan?",
        "answer": "Yes—bring a snack and eat right away.\n"
      },
      {
        "question": "Do I need a referral?",
        "answer": "Any doctor’s prescription works; walk-ins with referral accepted."
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "Open-bore scanner + mirror + music + optional sedative = comfortable ride.\n"
      },
      {
        "question": "How soon will results be ready?",
        "answer": "Same evening for in-house cases; 24 h max for complex reviews.\n"
      }
