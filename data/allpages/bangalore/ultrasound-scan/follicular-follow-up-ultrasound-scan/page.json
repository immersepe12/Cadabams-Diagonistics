    "seo": {
      "title": "Follicular Followup Ultrasound: Quick, Accurate",
      "description": "Schedule your Follicular Followup Ultrasound Scan at Cadabams Diagnostics for precise ovulation tracking, same-day reports, and expert fertility guidance.",
      "keywords": "",
      "canonicalUrl": "",
