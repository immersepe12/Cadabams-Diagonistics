    "faqs": [
      {
        "question": "How long does an MRI contrast scan take?",
        "answer": "45–60 minutes, including 5 minutes for dye injection.\n"
      },
      {
        "question": "Is gadolinium safe for kidneys?",
        "answer": "Yes, if your creatinine/eGFR is normal. We screen every patient first.\n"
      },
      {
        "question": "Can I drive home after MRI contrast?",
        "answer": "Yes, unless you received sedation. Arrange a companion if you feel dizzy.\n"
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "Open-bore MRI and mild sedation options are available—inform us in advance.\n"
      },
      {
        "question": "How soon will I get results?",
        "answer": "Within 24 hours; urgent cases are reported same day.\n"
      },
      {
        "question": "Does MRI contrast cause side effects?",
        "answer": "Mild cold sensation or metallic taste is common; serious reactions are extremely rare.\n"
      }
    ],
