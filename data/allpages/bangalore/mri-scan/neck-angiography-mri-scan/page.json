    "seo": {
      "title": "MRI Neck Angio (TOF) Test at Cadabams Diagnostics – Fast & Safe",
      "description": "Need a neck vessel scan? Learn how MRI Neck Angio (TOF) at Cadabams Diagnostics detects clots, stenosis & aneurysms quickly, safely, and without radiation.\n",
      "keywords": "",
      "canonicalUrl": "",
