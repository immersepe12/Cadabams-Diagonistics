    "faqs": [
      {
        "question": "Is MRI Scrotum painful?",
        "answer": "No. The scan is painless; you only need to remain still.\n"
      },
      {
        "question": "Can I eat before the scan?",
        "answer": "Yes for standard MRI. Fast 4–6 hours if contrast is required.\n"
      },
      {
        "question": "When will I get my MRI Scrotum results?",
        "answer": "A radiologist at Cadabams Diagnostics will interpret your images and a formal report will be sent to your referring physician, usually within 1-2 business days. Your physician will then share and discuss these results with you."
      },
      {
        "question": "When will I get my report?",
        "answer": "Same-day digital reports are emailed, and a printed copy is ready before you leave.\n"
      },
      {
        "question": "Do I need a doctor’s referral?",
        "answer": "Yes, to ensure the scan is medically appropriate.\n"
      },
      {
        "question": "What if I’m claustrophobic?",
        "answer": "We offer open-bore MRI and mild oral sedation on request.\n"
      }
