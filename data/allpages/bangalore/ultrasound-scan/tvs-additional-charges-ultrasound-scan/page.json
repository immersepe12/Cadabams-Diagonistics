    "faqs": [
      {
        "question": "Why is there an extra charge for TVS compared to abdominal ultrasound?",
        "answer": "The single-use probe sheath, higher-frequency transducer, and specialised reporting justify the fee."
      },
      {
        "question": "Is the scan painful?",
        "answer": "Most feel mild pressure; pain is rare. A smaller probe (17 mm) is used for virginal or sensitive patients."
      },
      {
        "question": "Can I take the test during periods?",
        "answer": "Yes, unless the doctor specifically requests follicular-phase timing."
      },
      {
        "question": "How soon will I get the report?",
        "answer": "Within 2 hours via email/SMS; urgent cases prioritised in 30 minutes."
      },
      {
        "question": "Is insurance coverage available?",
        "answer": "Many insurers cover TVS under maternity or diagnostic benefits—check with your provider."
      },
      {
        "question": "Do I need a full bladder?",
        "answer": "No. An empty bladder gives clearer images and reduces discomfort."
      }
    ],
