    "faqs": [
      {
        "question": "Is the HSG X-Ray Scan painful?",
        "answer": "Most women feel mild cramps; taking a painkiller beforehand keeps discomfort minimal."
      },
      {
        "question": "Can the test actually improve fertility?",
        "answer": "Yes, the dye sometimes flushes small debris or mucus plugs, increasing conception odds in the same cycle."
      },
      {
        "question": "How soon can I try to conceive after the scan?",
        "answer": "You can start trying right away if no complications are noted."
      },
      {
        "question": "Is the radiation dose high",
        "answer": "No, it’s very low—about the same as 2–3 chest X-rays."
      },
      {
        "question": "When will I get my results?",
        "answer": "Preliminary findings are shared the same day; your full report is ready within 24 hours."
      },
      {
        "question": "Do I need a referral?",
        "answer": "A referral is preferred; however, walk-ins are accepted if you bring prior medical records."
      }
