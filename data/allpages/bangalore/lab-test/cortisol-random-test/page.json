    "faqs": [
      {
        "question": "What does “stress hormone” mean and how is it relevant to cortisol?  ",
        "answer": "Cortisol manages the body’s reaction to stress by controlling blood sugar, metabolism, and inflammation."
      },
      {
        "question": "Can one random cortisol test give a conclusive diagnosis?  ",
        "answer": "A random cortisol test presents helpful clues but is often combined with further testing like **ACTH stimulation test** or **dexamethasone suppression test** for precise diagnosis."
      },
      {
        "question": "What are some of the factors that can alter cortisol levels?  ",
        "answer": "Lack of sleep, stress, surgery, infections, and medications can alter cortisol levels."
      },
      {
        "question": "Should I stop taking any medicines prior to the test?  ",
        "answer": "Stop taking medications only if instructed by your physician, as some drugs like corticosteroids can alter test outcomes."
      },
      {
        "question": "How long does it take to get results?  ",
        "answer": "Most often between 1 and 2 days depending on the lab."
      }
    ],
    "interpretations": {
      "title": "Interpreting the Results of Your Cortisol Random Test ",
      "cols": [
        "Condition/Findings ",
        "Description ",
        "Interpretation "
      ],
      "rows": [
        [
          "Normal Cortisol Level ",
          "Varies depending on time but roughly 6–23 mcg/dL. ",
          "Indicates healthy adrenal gland function. "
        ],
        [
          "Low Cortisol (Hypocortisolism) ",
          "Levels below the normal range. ",
          "Suggests Addison’s disease, adrenal insufficiency, or pituitary dysfunction. "
        ],
        [
          "High Cortisol (Hypercortisolism) ",
          "Elevated levels outside the expected range. ",
          "Could indicate Cushing’s syndrome, chronic stress, depression, or use of steroid medications. "
        ]
      ]
